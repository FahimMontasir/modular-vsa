{
  "$schema": "https://v2-9-8.turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["^check"],
      "description": "Lint, format, and typecheck all code"
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "description": "Run unit tests"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "dkr:start": {
      "cache": false,
      "persistent": true
    },
    "dkr:stop": {
      "cache": false
    },
    "dkr:down": {
      "cache": false
    }
  }
}
