{
  "name": "modular-vsa",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "17.4.2",
      "zod": "4.3.6",
      "typescript": "6",
      "@types/bun": "^1.3.13",
      "better-auth": "1.6.9",
      "@tanstack/react-form": "1.29.1",
      "@types/react-dom": "19.2.3",
      "@better-auth/expo": "1.5.5",
      "@sinclair/typebox": "0.34.49",
      "elysia": "1.4.28",
      "drizzle-typebox": "0.3.3",
      "drizzle-orm": "0.45.2",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "@types/react": "19.2.14",
      "vite": "8.0.10",
      "tailwindcss": "4.2.4"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "git config --local core.hooksPath .github/hooks",
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check",
    "test:unit": "turbo test:unit",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @modular-vsa/db db:push",
    "db:studio": "turbo -F @modular-vsa/db db:studio",
    "db:generate": "turbo -F @modular-vsa/db db:generate",
    "db:migrate": "turbo -F @modular-vsa/db db:migrate",
    "dkr:start": "turbo -F server dkr:start",
    "dkr:stop": "turbo -F server dkr:stop",
    "dkr:down": "turbo -F server dkr:down",
    "update:deps": "bun update --interactive --recursive"
  },
  "dependencies": {
    "@modular-vsa/env": "workspace:*",
    "@sinclair/typebox": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-typebox": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@modular-vsa/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
