{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check": "oxlint && oxfmt --write && tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "dkr:start": "docker compose up -d",
    "dkr:stop": "docker compose stop",
    "dkr:down": "docker compose down"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@elysia/server-timing": "^1.4.1",
    "@elysiajs/cors": "^1.4.2",
    "@modular-vsa/auth": "workspace:*",
    "@modular-vsa/db": "workspace:*",
    "@modular-vsa/env": "workspace:*",
    "@modular-vsa/home": "workspace:*",
    "@modular-vsa/security": "workspace:*",
    "@modular-vsa/utils": "workspace:*",
    "@sinclair/typebox": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@modular-vsa/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.10",
    "typescript": "catalog:"
  }
}
